/* JoeMail - Premiumisme.info clone */

:root {
    --head-font: 'Kadwa';
    --body-font: 'Poppins';
    --primary: #1a1a1a;
    --secondary: #ff6b4a;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html, body {
    line-height: 1.5;
    font-family: var(--body-font), ui-sans-serif, system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
    background-color: #1a1a1a !important;
    color: #f5f5f5 !important;
}


/* Dark mode base overrides */

/* Dark mode - dark: prefix classes (must come AFTER base overrides to win specificity) */

h1, h2, h3, h4, h5, h6 { font-family: var(--head-font), serif; }
a { color: inherit; text-decoration: none; }

/* ============================================================ */
/* UTILITIES */
/* ============================================================ */
.min-h-screen { min-height: 100vh; }
.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-1 { flex: 1; }
.inline { display: inline; }
.grid { display: grid; }
.grid-cols-1 { grid-template-columns: repeat(1, 1fr); }
.grid-cols-3 { grid-template-columns: repeat(3, 1fr); }
.grid-cols-6 { grid-template-columns: repeat(6, 1fr); }
.hidden { display: none !important; }
.items-center { align-items: center; }
.items-end { align-items: flex-end; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.justify-end { justify-content: flex-end; }
.text-center { text-align: center; }
.text-start { text-align: start; }
.text-left { text-align: left; }
.truncate { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.select-none { user-select: none; }
.cursor-pointer { cursor: pointer; }
.relative { position: relative; }
.absolute { position: absolute; }
.fixed { position: fixed; }
.inset-0 { top: 0; right: 0; bottom: 0; left: 0; }
.inset-y-0 { top: 0; bottom: 0; }
.top-0 { top: 0; }
.left-0 { left: 0; }
.right-0 { right: 0; }
.bottom-0 { bottom: 0; }
.top-5 { top: 1.25rem; }
.right-5 { right: 1.25rem; }
.bottom-5 { bottom: 1.25rem; }
.z-10 { z-index: 10; }
.z-50 { z-index: 50; }
.block { display: block; }
.appearance-none { appearance: none; }
.w-full { width: 100%; }
.w-screen { width: 100vw; }
.h-full { height: 100%; }
.h-6 { height: 1.5rem; }
.h-80 { height: 20rem; }
.h-screen { height: 100vh; }
.max-w-full { max-width: 100%; }
.max-w-email-dropdown { max-width: 280px; }
.max-w-40 { max-width: 10rem; }
.overflow-hidden { overflow: hidden; }
.overflow-y-auto { overflow-y: auto; }
.pointer-events-none { pointer-events: none; }
.whitespace-nowrap { white-space: nowrap; }

/* Spacing */
.p-2 { padding: 0.5rem; }
.p-4 { padding: 1rem; }
.p-5 { padding: 1.25rem; }
.p-6 { padding: 1.5rem; }
.px-3 { padding-left: 0.75rem; padding-right: 0.75rem; }
.px-4 { padding-left: 1rem; padding-right: 1rem; }
.px-5 { padding-left: 1.25rem; padding-right: 1.25rem; }
.pr-8 { padding-right: 2rem; }
.px-6 { padding-left: 1.5rem; padding-right: 1.5rem; }
.py-1 { padding-top: 0.25rem; padding-bottom: 0.25rem; }
.py-2 { padding-top: 0.5rem; padding-bottom: 0.5rem; }
.py-3 { padding-top: 0.75rem; padding-bottom: 0.75rem; }
.py-4 { padding-top: 1rem; padding-bottom: 1rem; }
.py-5 { padding-top: 1.25rem; padding-bottom: 1.25rem; }
.py-10 { padding-top: 2.5rem; padding-bottom: 2.5rem; }
.pb-5 { padding-bottom: 1.25rem; }
.pb-10 { padding-bottom: 2.5rem; }
.pb-20 { padding-bottom: 5rem; }
.pt-4 { padding-top: 1rem; }
.mb-1 { margin-bottom: 0.25rem; }
.mb-2 { margin-bottom: 0.5rem; }
.mb-4 { margin-bottom: 1rem; }
.mb-5 { margin-bottom: 1.25rem; }
.m-2 { margin: 0.5rem; }
.m-3 { margin: 0.75rem; }
.m-4 { margin: 1rem; }
.m-5 { margin: 1.25rem; }
.ml-2 { margin-left: 0.5rem; }
.ml-3 { margin-left: 0.75rem; }
.mr-2 { margin-right: 0.5rem; }
.mt-1 { margin-top: 0.25rem; }
.mt-2 { margin-top: 0.5rem; }
.mt-3 { margin-top: 0.75rem; }
.mt-4 { margin-top: 1rem; }
.mt-8 { margin-top: 2rem; }
.mx-5 { margin-left: 1.25rem; margin-right: 1.25rem; }

/* Gap */
.gap-3 { gap: 0.75rem; }
.gap-5 { gap: 1.25rem; }
.space-x-3 > * + * { margin-left: 0.75rem; }
.space-y-2 > * + * { margin-top: 0.5rem; }
.space-y-3 > * + * { margin-top: 0.75rem; }
.space-y-5 > * + * { margin-top: 1.25rem; }

/* Border */
.border-0 { border-width: 0; }
.border { border-width: 1px; border-style: solid; }
.border-2 { border-width: 2px; }
.border-dashed { border-style: dashed; }
.border-white { border-color: white; }
.border-opacity-10 { border-color: rgba(255,255,255,0.1); }
.rounded { border-radius: 0.25rem; }
.rounded-md { border-radius: 0.375rem; }
.rounded-lg { border-radius: 0.5rem; }
.ring-1 { box-shadow: 0 0 0 1px; }
.ring-black { --tw-ring-color: rgba(0,0,0,1); }
.ring-opacity-5 { --tw-ring-opacity: 0.05; }

/* Background */
.bg-primary { background-color: transparent !important; }
.bg-secondary { background-color: #ff6b4a !important; }
.bg-white { background-color: #242424 !important; }
.bg-gray-100 { background-color: #1a1a1a !important; }
.bg-gray-800 { background-color: #242424 !important; }
.bg-gray-900 { background-color: #1a1a1a !important; }
.bg-black\/50 { background-color: rgba(0,0,0,0.5); }
.bg-indigo-600 { background-color: #ff6b4a !important; }
.bg-yellow-300 { background-color: #fde047; }
.bg-green-400 { background-color: #4ade80; }
.bg-opacity-10 { background-color: rgba(255,255,255,0.1); }
.bg-opacity-25 { background-color: rgba(255,255,255,0.25); }
.bg-opacity-50 { background-color: rgba(255,255,255,0.5); }
.hover\:bg-opacity-10:hover { background-color: rgba(255,255,255,0.1); }
.hover\:bg-opacity-25:hover { background-color: rgba(255,255,255,0.25); }
.hover\:bg-opacity-75:hover { background-color: rgba(255,255,255,0.75); }
.hover\:bg-secondary\/90:hover { background-color: rgba(255,107,74,0.9) !important; }

/* Text */
.text-white { color: #fff; }
.text-gray-200 { color: #f5f5f5 !important; }
.text-gray-300 { color: #e0e0e0 !important; }
.text-gray-400 { color: #b3b3b3 !important; }
.text-gray-500 { color: #999 !important; }
.text-gray-700 { color: #d1d5db !important; }
.text-gray-800 { color: #f5f5f5 !important; }
.text-gray-900 { color: #f5f5f5 !important; }
.text-yellow-500 { color: #eab308; }
.text-sm { font-size: 0.875rem; line-height: 1.25rem; }
.text-lg { font-size: 1.125rem; line-height: 1.75rem; }
.text-3xl { font-size: 1.875rem; line-height: 2.25rem; }
.font-bold { font-weight: 700; }
.font-semibold { font-weight: 600; }
.opacity-75 { opacity: 0.75; }
.placeholder-white::placeholder { color: rgba(255,255,255,0.5); }
.placeholder-opacity-50::placeholder { opacity: 0.5; }
.focus\:outline-none:focus { outline: none; }
.transition-colors { transition: color 0.15s, background-color 0.15s, border-color 0.15s; }
.transition-all { transition: all 0.3s ease; }
.backdrop-blur-sm { backdrop-filter: blur(4px); }
.shadow-lg { box-shadow: 0 10px 15px -3px rgba(0,0,0,.1), 0 4px 6px -2px rgba(0,0,0,.05); }
.shadow-xl { box-shadow: 0 20px 25px -5px rgba(0,0,0,.1), 0 8px 10px -6px rgba(0,0,0,.05); }

/* Prose for email body */
.prose { line-height: 1.75; max-width: 65ch; }
.prose-invert { color: #f5f5f5; }
.prose a { color: #93c5fd; text-decoration: underline; }
.prose p { margin-top: 0.75em; margin-bottom: 0.75em; }
.prose h1, .prose h2, .prose h3 { font-weight: 700; margin-top: 1.5em; margin-bottom: 0.5em; }
.max-w-none { max-width: none; }

/* ============================================================ */
/* LAYOUT RESPONSIVE */
/* ============================================================ */
@media (min-width: 1024px) {
    .lg\:flex { display: flex !important; }
    .lg\:block { display: block !important; }
    .lg\:hidden { display: none !important; }
    .lg\:flex-row { flex-direction: row; }
    .lg\:order-first { order: -9999; }
    .lg\:grid-cols-3 { grid-template-columns: repeat(3, 1fr); }
    .lg\:grid-cols-6 { grid-template-columns: repeat(6, 1fr); }
    .lg\:items-baseline { align-items: baseline; }
    .lg\:p-10 { padding: 2.5rem; }
    .lg\:px-0 { padding-left: 0; padding-right: 0; }
    .lg\:py-10 { padding-top: 2.5rem; padding-bottom: 2.5rem; }
    .lg\:pb-10 { padding-bottom: 2.5rem; }
    .lg\:mx-0 { margin-left: 0; margin-right: 0; }
    .lg\:my-8 { margin-top: 2rem; margin-bottom: 2rem; }
    .lg\:align-middle { vertical-align: middle; }
    .sm\:inline-block { display: inline-block; }
    .sm\:block { display: block; }
    .sm\:p-0 { padding: 0; }
    .sm\:mt-0 { margin-top: 0; }
    .sm\:text-left { text-align: left; }
    .sm\:align-middle { vertical-align: middle; }
    .sm\:h-screen { height: 100vh; }
    .sm\:my-8 { margin-top: 2rem; margin-bottom: 2rem; }
    .sm\:scale-95 { transform: scale(0.95); }
    .sm\:scale-100 { transform: scale(1); }
}

@media (min-width: 768px) {
    .md\:w-auto { width: auto; }
    .md\:inline { display: inline; }
}

@media (max-width: 640px) {
    .sm\:max-w-full { max-width: 100%; }
    .sm\:inline-block { display: inline-block; }
    .sm\:block { display: block; }
    .sm\:p-0 { padding: 0; }
    .sm\:mt-0 { margin-top: 0; }
    .sm\:text-left { text-align: left; }
    .sm\:align-middle { vertical-align: middle; }
    .sm\:h-screen { height: 100vh; }
    .sm\:my-8 { margin-top: 2rem; margin-bottom: 2rem; }
    .sm\:scale-95 { transform: scale(0.95); }
    .sm\:scale-100 { transform: scale(1); }
}

/* ============================================================ */
/* SPINNING ANIMATION */
/* ============================================================ */
@keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}
.fa-spin { animation: spin 1s infinite linear; }
.pause-spinner { animation-play-state: paused; }

/* ============================================================ */
/* TOAST */
/* ============================================================ */
.translate-y-0 { transform: translateY(0); }
.translate-y-20 { transform: translateY(5rem); }
.opacity-0 { opacity: 0; }
.opacity-100 { opacity: 1; }

/* ============================================================ */
/* INBOX ITEMS */
/* ============================================================ */
.inbox-item {
    background: #242424;
    border-radius: 0.5rem;
    padding: 1rem 1.25rem;
    cursor: pointer;
    transition: background-color 0.15s;
    font-size: 0.875rem;
}
.inbox-item:hover {
    background: #2e2e2e;
}
    background: #1f2937;
}
    background: #374151;
}
.inbox-item .from { font-weight: 600; }
.inbox-item .subject { opacity: 0.8; margin-top: 0.25rem; }
.inbox-item .date { font-size: 0.75rem; opacity: 0.5; }

/* ============================================================ */
/* DROPDOWN */
/* ============================================================ */
.dropdown-menu {
    transition: opacity 0.2s ease, transform 0.2s ease;
}
.dropdown-item {
    display: block;
    width: 100%;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    line-height: 1.25rem;
    color: #d1d5db;
    cursor: pointer;
    transition: background-color 0.15s;
}
.dropdown-item:hover {
    background: #2e2e2e;
}
    color: #d1d5db;
}
    background: #374151;
}

/* ============================================================ */
/* SMOOTH ANIMATIONS */
/* ============================================================ */

/* Dropdown animation (email history, domain selector) */
.dropdown-anim {
    opacity: 0;
    transform: translateY(-8px) scale(0.97);
    pointer-events: none;
    transition: opacity 0.2s cubic-bezier(0.4, 0, 0.2, 1),
                transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}
.dropdown-anim.open {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
}

/* View switch animation (email view <-> new email form) */
.view-anim {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.25s cubic-bezier(0.4, 0, 0.2, 1),
                transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}
.view-anim.open {
    opacity: 1;
    transform: translateY(0);
}

/* Modal animation (QR modal, mobile menu) */
.modal-anim {
    opacity: 0;
    transform: scale(0.95);
    transition: opacity 0.25s cubic-bezier(0.4, 0, 0.2, 1),
                transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}
.modal-anim.open {
    opacity: 1;
    transform: scale(1);
}



/* Inbox fade-in */
.inbox-fade-in {
    animation: inboxFadeIn 0.3s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}
@keyframes inboxFadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
}

/* Button press effect */
.btn-press {
    transition: transform 0.1s ease, box-shadow 0.1s ease;
}
.btn-press:active {
    transform: scale(0.96);
}

/* Toast slide-in */
#toast {
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
                opacity 0.25s ease;
}

/* ============================================================ */
/* MOBILE FIXES */
/* ============================================================ */
@media (max-width: 640px) {
    header { overflow-x: hidden; }



    .logo {
        min-width: 0;
        height: 23px;
    }

    .logo img {
        max-height: 23px;
        width: auto;
    }





    #email-section {
        padding-left: 1.25rem;
        padding-right: 1.25rem;
    }

    #email-view,
    #new-email-view {
        max-width: 100%;
        width: 100%;
    }

    #email-view > .border-2,
    #new-email-view > .border-2 {
        border-radius: 0.45rem;
    }

    #email-view .text-lg.font-bold {
        font-size: 1.125rem;
        line-height: 1.75rem;
        margin-top: 2rem;
        margin-bottom: 0.5rem;
    }
}

/* ============================================================ */
/* JoeMail Professional Theme Override - 2026 */
/* ============================================================ */
:root{
  --head-font:'Inter';
  --body-font:'Inter';
  --primary:#0f172a;
  --secondary:#2563eb;
  --accent:#38bdf8;
  --surface:#111827;
  --surface-2:#172033;
  --line:rgba(148,163,184,.22);
  --muted:#94a3b8;
  --text:#e5eefc;
}
html,body{background:#08111f!important;color:var(--text)!important;font-family:Inter,ui-sans-serif,system-ui,-apple-system,Segoe UI,Arial,sans-serif!important;}
body[style],.groot-theme[style]{background:radial-gradient(circle at 20% 0%,rgba(37,99,235,.22),transparent 36%),radial-gradient(circle at 80% 12%,rgba(56,189,248,.14),transparent 32%),linear-gradient(180deg,#08111f 0%,#0b1220 54%,#0f172a 100%)!important;background-size:auto!important;}
.groot-theme::before{content:"";position:fixed;inset:0;background-image:linear-gradient(rgba(148,163,184,.08) 1px,transparent 1px),linear-gradient(90deg,rgba(148,163,184,.08) 1px,transparent 1px);background-size:64px 64px;mask-image:linear-gradient(to bottom,rgba(0,0,0,.75),transparent);pointer-events:none;z-index:0}.groot-theme>*{position:relative;z-index:1}
.logo span{font-family:Inter,ui-sans-serif!important;font-size:1.65rem!important;letter-spacing:-.035em!important;font-weight:800!important}.logo span:before{content:"◆";display:inline-flex;margin-right:.55rem;color:#38bdf8;font-size:1rem;vertical-align:.15rem}.logo span:after{content:" Operations";font-size:.8rem;font-weight:700;color:#94a3b8;margin-left:.5rem;letter-spacing:.08em;text-transform:uppercase}
header{background:transparent!important}.grid.bg-gray-900,#inbox-section{background:transparent!important}.bg-gray-950,footer{background:rgba(2,6,23,.78)!important;border-top:1px solid var(--line);backdrop-filter:blur(18px)}
#email-view>.border-2,#new-email-view>.border-2,#inbox-empty,#email-detail>.bg-gray-800,.inbox-item{background:linear-gradient(180deg,rgba(17,24,39,.86),rgba(15,23,42,.92))!important;border:2px solid var(--line)!important;border-radius:8px!important;box-shadow:0 24px 80px rgba(0,0,0,.28),inset 0 1px 0 rgba(255,255,255,.04); border-style:solid!important;}.text-lg.font-bold{font-family:Inter!important;font-size:.78rem!important;text-transform:uppercase;letter-spacing:.14em;color:#94a3b8!important;font-weight:800!important}
#email-display,#new-username,#domain-display{background:rgba(15,23,42,.88)!important;border:1px solid rgba(148,163,184,.25)!important;border-radius:6px!important;color:#f8fafc!important;box-shadow:inset 0 1px 0 rgba(255,255,255,.04)}#email-display{font-size:1.02rem;font-weight:700;letter-spacing:.01em}.placeholder-white::placeholder{color:#64748b!important}.bg-gray-700,#email-dropdown-list,#domain-dropdown-list{background:#0f172a!important;border:1px solid var(--line)!important;border-radius:6px!important;box-shadow:0 20px 60px rgba(0,0,0,.35)}
#btn-copy,#btn-create-email,#btn-random,.bg-indigo-600{background:linear-gradient(135deg,#2563eb,#38bdf8)!important;color:white!important;border:0!important;box-shadow:0 12px 34px rgba(37,99,235,.28)}.actions>div,#btn-cancel{background:rgba(15,23,42,.72)!important;border:1px solid var(--line)!important;border-radius:6px!important;color:#dbeafe!important}.actions>div:hover,#btn-cancel:hover{background:rgba(37,99,235,.18)!important;border-color:rgba(56,189,248,.38)!important;transform:translateY(-1px)}
.inbox-item{border-radius:8px!important}.inbox-item:hover{background:linear-gradient(180deg,rgba(30,41,59,.92),rgba(15,23,42,.96))!important;border-color:rgba(56,189,248,.35)!important;transform:translateY(-1px)}.text-gray-200,.text-white{color:#f8fafc!important}.text-gray-300{color:#cbd5e1!important}.text-gray-400,.text-gray-500{color:#94a3b8!important}.prose a{color:#38bdf8!important}#toast{background:linear-gradient(135deg,#2563eb,#38bdf8)!important;border-radius:6px!important;box-shadow:0 18px 50px rgba(37,99,235,.35)}
@media(max-width:640px){#email-view>.border-2,#new-email-view>.border-2,#inbox-empty,#email-detail>.bg-gray-800{border-radius:6px!important}.logo span:after{display:none}.actions{gap:.55rem!important}.actions .text-sm{display:none}}

/* Front email switch precision fix */
#email-section{align-items:stretch!important}
#email-view,#new-email-view{width:100%!important;max-width:100%!important;opacity:1!important;transform:none!important;transition:opacity .12s ease!important}
#email-view>.border-2,#new-email-view>.border-2{border-width:2px!important;border-style:solid!important;border-radius:6px!important;display:flex!important;flex-direction:column!important;justify-content:center!important;box-sizing:border-box!important;min-height:156px!important}
#new-email-view>.border-2{padding:0!important}.view-anim{transform:none!important}.view-anim.open{transform:none!important}
#new-email-view .m-5{margin:0.75rem!important}.actions,#btn-cancel{height:44px!important}.actions>div,#btn-cancel{min-height:44px!important;box-sizing:border-box!important}
#btn-new,#btn-refresh,#btn-delete,#btn-cancel,#btn-copy,#btn-create-email,#btn-random{transition:background-color .14s ease,border-color .14s ease,box-shadow .14s ease!important}
#btn-new:active,#btn-refresh:active,#btn-delete:active,.btn-press:active{transform:none!important}
@media(max-width:640px){#email-view>.border-2,#new-email-view>.border-2{border-radius:18px!important}}

/* Frontend contrast maximal polish */
:root{--primary:#050b14!important;--secondary:#3b82f6!important;--accent:#67e8f9!important;--surface:#111c2e!important;--surface-2:#17243a!important;--line:rgba(203,213,225,.30)!important;--muted:#cbd5e1!important;--text:#f8fbff!important}
html,body{background:#050b14!important;color:#f8fbff!important}body[style],.groot-theme[style]{background:radial-gradient(circle at 20% 0%,rgba(59,130,246,.22),transparent 34%),radial-gradient(circle at 80% 12%,rgba(103,232,249,.14),transparent 30%),linear-gradient(180deg,#050b14,#0b1220)!important}
.logo span,.text-white,.text-gray-200,strong,b{color:#fff!important}.text-gray-300,.text-gray-400,.text-gray-500,.opacity-75{color:#cbd5e1!important;opacity:1!important}
#email-view>.border-2,#new-email-view>.border-2,#inbox-empty,#email-detail>.bg-gray-800,.inbox-item{background:linear-gradient(180deg,rgba(22,34,55,.96),rgba(12,20,35,.98))!important;border-color:rgba(203,213,225,.30)!important;box-shadow:0 24px 80px rgba(0,0,0,.34),inset 0 1px 0 rgba(255,255,255,.06)!important}
#email-display,#new-username,#domain-display{background:#0b1324!important;border-color:rgba(203,213,225,.38)!important;color:#fff!important}.placeholder-white::placeholder{color:#94a3b8!important}
.actions>div,#btn-cancel{background:rgba(30,41,59,.92)!important;border-color:rgba(203,213,225,.32)!important;color:#f8fbff!important}.actions>div:hover,#btn-cancel:hover{background:rgba(51,65,85,.98)!important;border-color:rgba(103,232,249,.55)!important}
#btn-copy,#btn-create-email,#btn-random,.bg-indigo-600{background:linear-gradient(135deg,#2563eb,#06b6d4)!important;color:#fff!important}.bg-gray-700,#email-dropdown-list,#domain-dropdown-list{background:#0b1324!important;border-color:rgba(203,213,225,.30)!important}.dropdown-item{color:#f8fbff!important}.dropdown-item:hover{background:rgba(59,130,246,.20)!important}.prose,.prose-invert,#detail-body{color:#f8fbff!important}.prose a{color:#67e8f9!important}
