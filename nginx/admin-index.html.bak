<!doctype html><html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>JoeMail Admin</title><style>:root{--background:#1a1a1a;--foreground:#f5f5f5;--card:#242424;--popover:#212121;--primary:#ff6b4a;--accent:#ff4fa0;--secondary:#2e2e2e;--muted:#333;--muted-foreground:#b3b3b3;--border:#474747;--input:#3d3d3d;--destructive:#e45454;--success:#29b36f;--warning:#f6ad28;--radius:14px}*{box-sizing:border-box;min-width:0}html{color-scheme:dark;background:var(--background);scroll-behavior:smooth}body{margin:0;min-height:100vh;background:linear-gradient(180deg,#1a1a1a 0%,#1f1f1f 52%,#242424 100%);color:var(--foreground);font-family:Inter,ui-sans-serif,system-ui,-apple-system,Segoe UI,Arial;font-size:14px;-webkit-font-smoothing:antialiased}body:before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(255,255,255,.055) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.055) 1px,transparent 1px);background-size:54px 54px;background-position:-1px -1px;pointer-events:none;z-index:0}.main:before{content:'';position:fixed;left:240px;right:0;top:64px;bottom:0;background-image:linear-gradient(rgba(255,255,255,.045) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.045) 1px,transparent 1px);background-size:54px 54px;pointer-events:none;z-index:-1}::selection{background:rgba(255,107,74,.26)}button,input,textarea,select{font:inherit;color-scheme:dark}button{border:1px solid var(--border);border-radius:10px;padding:8px 12px;background:#1f1f1f;color:var(--foreground);cursor:pointer;font-weight:600;transition:background .18s,border-color .18s,transform .18s}button:hover{background:var(--secondary);border-color:rgba(255,107,74,.35)}.primary{background:linear-gradient(135deg,var(--primary),var(--accent));border-color:transparent;color:#111}.danger{background:rgba(228,84,84,.10);border-color:rgba(228,84,84,.35);color:#ffb8b8}.ghost{background:#1f1f1f;border-color:rgba(71,71,71,.78)}input,textarea,select{width:100%;background:#1f1f1f;border:1px solid rgba(71,71,71,.86);border-radius:10px;color:var(--foreground);padding:10px 12px;outline:0}input:focus,textarea:focus,select:focus{border-color:rgba(255,107,74,.56);box-shadow:0 0 0 3px rgba(255,107,74,.10)}textarea{min-height:116px}.mut{color:var(--muted-foreground)}.bad{color:#ff8b8b}.ok{color:#6ee7a8}.warn{color:#facc6b}.login{min-height:100vh;display:grid;place-items:center;padding:24px;position:relative;z-index:1}.card{background:#242424;border:1px solid rgba(71,71,71,.82);border-radius:18px;padding:18px;box-shadow:0 10px 26px rgba(0,0,0,.22),0 0 20px rgba(255,107,74,.035);position:relative;overflow:auto}.card:before{content:'';position:absolute;inset:0;border-radius:inherit;padding:1px;background:linear-gradient(135deg,rgba(255,107,74,.34),rgba(255,79,160,.26),transparent 72%);-webkit-mask:linear-gradient(#fff 0 0) content-box,linear-gradient(#fff 0 0);-webkit-mask-composite:xor;mask-composite:exclude;pointer-events:none}.card:hover{border-color:rgba(255,107,74,.28);background:#282828;box-shadow:0 12px 30px rgba(0,0,0,.24),0 0 24px rgba(255,79,160,.045)}.app{position:relative;z-index:1;min-height:100vh}.sidebar{position:fixed;left:0;top:0;z-index:40;width:240px;height:100vh;background:#1a1a1a;border-right:1px solid rgba(71,71,71,.6);display:flex;flex-direction:column}.brand{height:64px;display:flex;align-items:center;gap:12px;padding:0 16px;border-bottom:1px solid rgba(71,71,71,.6);background:#1a1a1a;flex-shrink:0}.logo{width:32px;height:32px;border-radius:10px;background:#2e2e2e;border:1px solid var(--border);display:grid;place-items:center;font-weight:800;color:var(--foreground);flex-shrink:0}.brand h1{margin:0;font-size:14px;font-weight:650}.brand p{margin:2px 0 0;font-size:12px;color:var(--muted-foreground)}.nav{flex:1;padding:12px 8px;overflow-y:auto;scrollbar-width:none}.nav::-webkit-scrollbar{display:none}.nav button{width:100%;display:flex;align-items:center;gap:12px;padding:9px 12px;margin:2px 0;border:0;border-radius:8px;background:transparent;color:var(--muted-foreground);text-align:left;font-weight:550}.nav button:hover{background:#2e2e2e;color:var(--foreground)}.nav button.active{background:#2e2e2e;color:var(--foreground);box-shadow:inset 3px 0 0 var(--primary)}.ico{width:16px;height:16px;display:inline-grid;place-items:center;font-size:11px;color:inherit;flex-shrink:0}.sidefoot{border-top:1px solid var(--border);padding:8px}.sidefoot button{width:100%;display:flex;align-items:center;justify-content:flex-start;gap:12px;border:0;background:transparent;color:var(--muted-foreground);border-radius:8px}.sidefoot button:hover{background:#2e2e2e;color:var(--foreground)}.mainwrap{margin-left:240px;min-height:100vh}.appbar{height:64px;position:fixed;top:0;left:240px;right:0;z-index:30;background:rgba(26,26,26,.95);backdrop-filter:blur(10px);border-bottom:1px solid rgba(71,71,71,.6);display:flex;align-items:center;justify-content:space-between;padding:0 24px}.left{display:flex;align-items:center;gap:12px}.crumb{font-size:13px;color:var(--muted-foreground)}.main{padding:88px 24px 28px;overflow-x:hidden}.title{margin:0 0 18px;font-size:32px;line-height:1.1;font-weight:800;background:linear-gradient(135deg,#ff6b4a,#ff4fa0);-webkit-background-clip:text;background-clip:text;color:transparent;text-shadow:0 0 10px rgba(255,107,74,.18)}.grid{display:grid;grid-template-columns:repeat(12,minmax(0,1fr));gap:16px}.s12{grid-column:span 12}.s9{grid-column:span 9}.s8{grid-column:span 8}.s6{grid-column:span 6}.s4{grid-column:span 4}.s3{grid-column:span 3}.form{display:grid;grid-template-columns:repeat(12,minmax(0,1fr));gap:10px}.f1{grid-column:span 1}.f2{grid-column:span 2}.f3{grid-column:span 3}.f8{grid-column:span 8}.f9{grid-column:span 9}.f10{grid-column:span 10}.head{display:flex;justify-content:space-between;align-items:flex-start;gap:12px;margin-bottom:14px}.head h3,.card h3{margin:0 0 5px;font-size:16px}.num{font-size:31px;font-weight:800;margin:8px 0}.badge,.max-pill{display:inline-flex;align-items:center;gap:7px;padding:6px 9px;border-radius:999px;background:#1f1f1f;border:1px solid rgba(71,71,71,.78);color:var(--muted-foreground);font-size:12px;margin:2px}table{width:100%;border-collapse:collapse}th,td{padding:10px;border-bottom:1px solid rgba(71,71,71,.6);text-align:left;vertical-align:top}th{color:var(--muted-foreground);font-size:12px;font-weight:650}pre{margin:0;white-space:pre-wrap;word-break:break-word;max-height:520px;overflow:auto;background:#1f1f1f;border:1px solid var(--border);border-radius:12px;padding:13px;font-family:'JetBrains Mono','Fira Code','SF Mono',monospace;font-size:12px}.bottomnav{display:none}.cmd{position:fixed;inset:0;background:rgba(0,0,0,.62);display:none;align-items:flex-start;justify-content:center;padding-top:90px;z-index:99}.cmd.show{display:flex}.cmdbox{width:min(680px,92vw);background:#242424;border:1px solid var(--border);border-radius:18px;box-shadow:0 24px 80px rgba(0,0,0,.45);overflow:hidden}.cmdbox input{border:0;border-bottom:1px solid var(--border);border-radius:0;background:#202020;padding:17px 18px;font-size:16px}.cmdres{max-height:430px;overflow:auto;padding:10px}.cmditem{display:flex;align-items:center;justify-content:space-between;gap:12px;padding:12px 14px;border-radius:12px;cursor:pointer}.cmditem:hover{background:#303030}.cmdkey,.kbd{font-size:11px;color:#cfcfcf;border:1px solid var(--border);padding:3px 7px;border-radius:7px;background:#202020}.quick{min-width:250px}.mobile-menu{display:none}.healthbar{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px}.healthpill{background:#1f1f1f;border:1px solid rgba(71,71,71,.78);border-radius:14px;padding:11px 13px}.healthpill b{display:block;font-size:18px;margin-top:4px}#toast{position:fixed;right:18px;bottom:18px;background:#242424;border:1px solid var(--border);border-radius:12px;padding:12px 14px;z-index:120;display:none}.login-card{width:min(430px,92vw);padding:28px}.loginbrand{display:flex;align-items:center;gap:12px;margin-bottom:22px}.loginbrand h1{margin:0;font-size:22px;font-weight:800;background:linear-gradient(135deg,#ff6b4a,#ff4fa0);-webkit-background-clip:text;background-clip:text;color:transparent}.loginbrand p{margin:2px 0 0;font-size:12px;color:var(--muted-foreground)}.nav button.active .ico{color:#ff6b4a;text-shadow:0 0 10px rgba(255,107,74,.28)}.nav button:hover .ico{color:#f5f5f5}.sidebar .logo{box-shadow:0 0 0 1px rgba(255,107,74,.08),0 0 18px rgba(255,107,74,.06)}.appbar .max-pill{box-shadow:0 0 0 1px rgba(41,179,111,.09)}.card h3{letter-spacing:.01em}.card .mut{font-size:13px}.title:after{content:'';display:block;width:72px;height:3px;border-radius:99px;margin-top:10px;background:linear-gradient(90deg,#ff6b4a,#ff4fa0)}@keyframes status-pulse{0%,100%{opacity:1}50%{opacity:.4}}@media(max-width:1023px){.sidebar{display:flex;left:0;width:240px;transform:translateX(-104%);transition:transform .22s ease;box-shadow:18px 0 50px rgba(0,0,0,.45)}.sidebar.show{transform:translateX(0)}.mainwrap{margin-left:0}.appbar{display:flex;left:0;padding:0 14px}.appbar .mobile-menu{display:inline-flex}.main{padding:88px 14px 28px}.main:before{left:0}.title{font-size:28px}.bottomnav{display:none!important}.quick{display:none}.grid,.form{grid-template-columns:1fr}.s12,.s9,.s8,.s6,.s4,.s3,.f1,.f2,.f3,.f8,.f9,.f10{grid-column:1}.healthbar{grid-template-columns:repeat(2,1fr)}}
/* JoeMail Admin Professional Theme Override 2026 */
:root{--background:#08111f;--foreground:#e5eefc;--card:rgba(17,24,39,.88);--popover:#0f172a;--primary:#2563eb;--accent:#38bdf8;--secondary:#172033;--muted:#1e293b;--muted-foreground:#94a3b8;--border:rgba(148,163,184,.22);--input:#111827;--destructive:#ef4444;--success:#22c55e;--warning:#f59e0b;--radius:18px}body{background:radial-gradient(circle at 18% 0%,rgba(37,99,235,.22),transparent 34%),radial-gradient(circle at 84% 10%,rgba(56,189,248,.16),transparent 30%),linear-gradient(180deg,#08111f 0%,#0b1220 55%,#0f172a 100%)!important;color:var(--foreground)!important}.card,.login-card{background:linear-gradient(180deg,rgba(17,24,39,.88),rgba(15,23,42,.94))!important;border:1px solid var(--border)!important;border-radius:22px!important;box-shadow:0 24px 80px rgba(0,0,0,.30),inset 0 1px 0 rgba(255,255,255,.04)!important}.sidebar,.appbar,.bottomnav{background:rgba(2,6,23,.72)!important;border-color:var(--border)!important;backdrop-filter:blur(18px)!important}.brand .logo,.loginbrand .logo{background:linear-gradient(135deg,#2563eb,#38bdf8)!important;color:#fff!important;box-shadow:0 12px 34px rgba(37,99,235,.3)}button.primary,.primary{background:linear-gradient(135deg,#2563eb,#38bdf8)!important;color:#fff!important;border:0!important}button:hover{border-color:rgba(56,189,248,.45)!important}.nav button.active,.bottomnav button.active{background:rgba(37,99,235,.18)!important;border-color:rgba(56,189,248,.36)!important;color:#f8fafc!important}.title{letter-spacing:-.04em!important}.badge,.max-pill,.healthpill{background:rgba(15,23,42,.72)!important;border:1px solid var(--border)!important;border-radius:999px!important}input,textarea,select{background:rgba(15,23,42,.88)!important;border:1px solid rgba(148,163,184,.24)!important;border-radius:14px!important;color:#f8fafc!important}table{border-color:var(--border)!important}th{color:#94a3b8!important}tr:hover td{background:rgba(37,99,235,.08)!important}.num{letter-spacing:-.055em!important}

/* JoeMail Admin Responsive UX Maximal 2026 */
:root{--admin-sidebar:260px;--admin-gap:18px;--orange:#ff6b4a;--blue:#2563eb;--cyan:#38bdf8;--bg0:#080d16;--bg1:#0d1422;--panel:rgba(15,23,42,.82);--panel2:rgba(17,24,39,.94);--line:rgba(148,163,184,.20);--soft:rgba(148,163,184,.10)}
html,body,#root{width:100%;min-height:100%;overflow-x:hidden}body{background:radial-gradient(circle at 18% 0%,rgba(255,107,74,.13),transparent 28%),radial-gradient(circle at 82% 12%,rgba(56,189,248,.14),transparent 28%),linear-gradient(180deg,var(--bg0),var(--bg1))!important}.app{min-height:100vh;display:grid!important;grid-template-columns:var(--admin-sidebar) minmax(0,1fr)!important}.sidebar{position:sticky!important;top:0;height:100vh!important;overflow-y:auto!important;padding:18px 14px!important;border-right:1px solid var(--line)!important}.brand{gap:12px!important;margin-bottom:18px!important}.brand h1{font-size:20px!important;letter-spacing:-.04em!important}.brand p{font-size:12px!important;color:#94a3b8!important}.nav{display:flex!important;flex-direction:column!important;gap:7px!important}.nav button,.sidefoot button{width:100%!important;justify-content:flex-start!important;gap:10px!important;border-radius:14px!important;padding:11px 12px!important}.nav button.active{background:linear-gradient(135deg,rgba(255,107,74,.18),rgba(37,99,235,.16))!important;border-color:rgba(255,107,74,.34)!important}.ico{flex:0 0 auto;display:inline-flex!important;align-items:center!important;justify-content:center!important;width:34px!important;height:28px!important;border-radius:10px!important;background:rgba(255,255,255,.06)!important;color:#ffb199!important;font-size:11px!important;font-weight:800!important}.mainwrap{min-width:0!important;width:100%!important}.appbar{position:sticky!important;top:0;z-index:20;height:auto!important;min-height:64px!important;padding:12px 18px!important;display:flex!important;align-items:center!important;justify-content:space-between!important;gap:12px!important;border-bottom:1px solid var(--line)!important}.appbar>div:last-child{display:flex!important;gap:10px!important;align-items:center!important;flex-wrap:wrap!important;justify-content:flex-end!important}.main{width:100%!important;max-width:1540px!important;margin:0 auto!important;padding:24px!important;min-width:0!important;overflow:visible!important}.title{font-size:clamp(28px,4vw,48px)!important;line-height:1!important;margin:0 0 22px!important;background:linear-gradient(135deg,#fff,#c7d2fe 50%,#ffb199)!important;-webkit-background-clip:text!important;background-clip:text!important;color:transparent!important}.grid{display:grid!important;grid-template-columns:repeat(12,minmax(0,1fr))!important;gap:var(--admin-gap)!important;align-items:start!important}.card{min-width:0!important;width:100%!important;padding:18px!important;overflow:hidden!important;border-radius:22px!important}.s12{grid-column:span 12!important}.s9{grid-column:span 9!important}.s8{grid-column:span 8!important}.s6{grid-column:span 6!important}.s4,.s3{grid-column:span 3!important}.head{display:flex!important;align-items:flex-start!important;justify-content:space-between!important;gap:14px!important;flex-wrap:wrap!important;margin-bottom:14px!important}.head h3,.card h3{margin:0 0 10px!important;font-size:17px!important;letter-spacing:-.02em!important}.mut{color:#94a3b8!important}.badge,.max-pill,.healthpill{display:inline-flex!important;align-items:center!important;gap:7px!important;margin:3px 5px 3px 0!important;padding:7px 10px!important;white-space:normal!important}.healthbar{display:grid!important;grid-template-columns:repeat(4,minmax(0,1fr))!important;gap:12px!important;margin-bottom:18px!important}.healthpill{justify-content:space-between!important;border-radius:16px!important;background:rgba(15,23,42,.70)!important}.form{display:grid!important;grid-template-columns:repeat(12,minmax(0,1fr))!important;gap:12px!important;align-items:end!important}.form>*{min-width:0!important}.form .f1{grid-column:span 1!important}.form .f2{grid-column:span 2!important}.form .f3{grid-column:span 3!important}.form .f8{grid-column:span 8!important}.form .f9{grid-column:span 9!important}.form .f10{grid-column:span 10!important}label{display:flex!important;flex-direction:column!important;gap:7px!important;color:#cbd5e1!important;font-weight:700!important;font-size:12px!important;text-transform:uppercase!important;letter-spacing:.04em!important}input,textarea,select,button{max-width:100%!important}input,textarea,select{width:100%!important;min-height:42px!important;padding:10px 12px!important;border-radius:14px!important}textarea{min-height:110px!important;resize:vertical!important}button{min-height:40px!important;display:inline-flex!important;align-items:center!important;justify-content:center!important;gap:8px!important;white-space:normal!important;line-height:1.15!important}button.primary,.primary{background:linear-gradient(135deg,var(--orange),#ff4fa0)!important;color:#fff!important;box-shadow:0 14px 38px rgba(255,107,74,.20)!important}.ghost{background:rgba(15,23,42,.70)!important}.danger{background:rgba(239,68,68,.13)!important;color:#fecaca!important;border-color:rgba(239,68,68,.35)!important}.card table,table{display:block!important;width:100%!important;max-width:100%!important;overflow-x:auto!important;overflow-y:hidden!important;border-collapse:separate!important;border-spacing:0!important;-webkit-overflow-scrolling:touch!important;white-space:nowrap!important}.card table tbody,table tbody{display:table!important;width:100%!important;min-width:760px!important}.card:has(table)::after{content:'← geser tabel →';display:block;margin-top:8px;color:#64748b;font-size:11px;text-align:right}th,td{padding:12px 14px!important;border-bottom:1px solid rgba(148,163,184,.12)!important;vertical-align:top!important;max-width:520px!important}td{color:#dbeafe!important}td:nth-child(3),td:nth-child(4),td:nth-child(5){white-space:normal!important;word-break:break-word!important}pre{width:100%!important;max-width:100%!important;overflow:auto!important;white-space:pre-wrap!important;word-break:break-word!important;line-height:1.55!important;background:rgba(2,6,23,.45)!important;border:1px solid rgba(148,163,184,.14)!important;border-radius:16px!important;padding:14px!important}.num{font-size:clamp(24px,3.4vw,40px)!important}.login{min-height:100vh!important;display:grid!important;place-items:center!important;padding:20px!important}.login-card{width:min(440px,100%)!important}.bottomnav{display:none!important}.mobile-menu{display:none!important}
@media(max-width:1180px){:root{--admin-sidebar:224px}.main{padding:20px!important}.s3,.s4{grid-column:span 6!important}.s8,.s9{grid-column:span 12!important}.healthbar{grid-template-columns:repeat(2,minmax(0,1fr))!important}.form .f1,.form .f2,.form .f3{grid-column:span 4!important}.form .f8,.form .f9,.form .f10{grid-column:span 12!important}}
@media(max-width:820px){.app{display:block!important;padding-bottom:76px!important}.sidebar{position:fixed!important;left:0;top:0;bottom:0;width:min(86vw,320px)!important;height:100vh!important;z-index:60!important;transform:translateX(-105%)!important;transition:transform .22s ease!important;box-shadow:30px 0 80px rgba(0,0,0,.42)!important}.sidebar.show{transform:translateX(0)!important}.mobile-menu{display:inline-flex!important}.appbar{position:sticky!important;padding:10px 12px!important}.quick{display:none!important}.main{padding:18px 12px!important}.grid{grid-template-columns:repeat(6,minmax(0,1fr))!important;gap:12px!important}.s12,.s9,.s8,.s6,.s4,.s3{grid-column:span 6!important}.healthbar{grid-template-columns:repeat(2,minmax(0,1fr))!important}.form{grid-template-columns:repeat(6,minmax(0,1fr))!important}.form .f1,.form .f2,.form .f3,.form .f8,.form .f9,.form .f10,.form>*{grid-column:span 6!important}.card{padding:15px!important;border-radius:18px!important}.head{display:block!important}.head>*+*{margin-top:10px!important}.bottomnav{position:fixed!important;left:10px!important;right:10px!important;bottom:10px!important;z-index:50!important;display:grid!important;grid-template-columns:repeat(5,1fr)!important;gap:6px!important;padding:8px!important;border:1px solid var(--line)!important;border-radius:20px!important;background:rgba(2,6,23,.82)!important;backdrop-filter:blur(18px)!important}.bottomnav button{padding:8px 5px!important;min-height:48px!important;font-size:11px!important;flex-direction:column!important}.bottomnav .ico{width:28px!important;height:22px!important;font-size:10px!important}table tbody{min-width:680px!important}th,td{padding:10px!important}.toast{left:12px!important;right:12px!important;bottom:84px!important;width:auto!important}}
@media(max-width:520px){.main{padding:14px 10px!important}.title{font-size:30px!important}.healthbar{grid-template-columns:1fr!important}.appbar>div:last-child{gap:6px!important}.appbar button,.max-pill{font-size:12px!important;padding:8px 9px!important}.card{padding:13px!important}.num{font-size:26px!important}table tbody{min-width:620px!important}.brand h1{font-size:18px!important}}

.dns-list{display:grid!important;grid-template-columns:repeat(2,minmax(0,1fr))!important;gap:12px!important}.dns-card{display:grid!important;grid-template-columns:64px minmax(0,1fr) auto!important;gap:12px!important;align-items:start!important;padding:14px!important;border:1px solid rgba(148,163,184,.18)!important;border-radius:18px!important;background:rgba(2,6,23,.28)!important}.dns-type{display:flex!important;align-items:center!important;justify-content:center!important;height:42px!important;border-radius:14px!important;background:linear-gradient(135deg,#ff6b4a,#2563eb)!important;font-weight:900!important}.dns-fields{display:grid!important;grid-template-columns:1fr!important;gap:10px!important}.dns-fields input,.dns-fields textarea{font-family:ui-monospace,SFMono-Regular,Menlo,monospace!important;font-size:12px!important;text-transform:none!important;letter-spacing:0!important}.dns-fields textarea{min-height:72px!important}.dns-health{display:grid!important;gap:10px!important}.health-row{display:grid!important;grid-template-columns:120px 100px minmax(0,1fr)!important;gap:12px!important;align-items:center!important;padding:12px!important;border:1px solid rgba(148,163,184,.15)!important;border-radius:14px!important;background:rgba(15,23,42,.42)!important}.health-row code{white-space:normal!important;word-break:break-word!important;color:#cbd5e1!important}.badge.ok{color:#86efac!important}.badge.bad{color:#fecaca!important}@media(max-width:900px){.dns-list{grid-template-columns:1fr!important}.dns-card{grid-template-columns:1fr!important}.dns-type{width:64px!important}.health-row{grid-template-columns:1fr!important}}

/* DNS readability hotfix */
.dns-list{grid-template-columns:1fr!important}.dns-card{grid-template-columns:1fr!important;overflow:visible!important}.dns-top{display:flex!important;align-items:center!important;justify-content:space-between!important;gap:10px!important;flex-wrap:wrap!important}.dns-fields{grid-template-columns:180px 120px minmax(0,1fr)!important;align-items:start!important}.dns-value{grid-column:auto!important}.dns-value pre{margin:0!important;min-height:54px!important;white-space:pre-wrap!important;overflow:visible!important}.dns-card label{text-transform:none!important;letter-spacing:0!important}.dns-raw{margin-top:14px!important}.dns-raw summary{cursor:pointer;color:#cbd5e1;font-weight:800;padding:10px 0}.main .form{overflow:visible!important}.main .form button{width:100%!important}@media(max-width:1200px){.dns-fields{grid-template-columns:1fr!important}.dns-value{grid-column:1!important}.dns-top{align-items:flex-start!important}.dns-top button{width:100%!important}}

/* DNS no-cut final */
.dns-fields{display:grid!important;grid-template-columns:1fr 1fr!important;gap:10px!important}.dns-value{grid-column:1 / -1!important}.dns-value pre{display:block!important;width:100%!important;max-width:none!important;white-space:pre-wrap!important;overflow:visible!important;word-break:break-all!important;font-size:12px!important;line-height:1.55!important;padding:12px!important}.dns-card{max-width:100%!important;overflow:visible!important}.dns-card input{overflow:visible!important;text-overflow:clip!important}@media(max-width:700px){.dns-fields{grid-template-columns:1fr!important}}

/* JoeMail Maximal Admin Update 2026 */
body{background:radial-gradient(circle at 8% 0%,rgba(255,107,74,.16),transparent 25%),radial-gradient(circle at 78% 2%,rgba(37,99,235,.18),transparent 28%),radial-gradient(circle at 55% 80%,rgba(56,189,248,.08),transparent 34%),#07101d!important}.app{grid-template-columns:280px minmax(0,1fr)!important}.sidebar{background:linear-gradient(180deg,rgba(3,7,18,.94),rgba(15,23,42,.88))!important;border-right:1px solid rgba(148,163,184,.18)!important;box-shadow:12px 0 60px rgba(0,0,0,.22)!important}.brand{padding:10px 8px 18px!important;border-bottom:1px solid rgba(148,163,184,.12)!important}.brand .logo{width:48px!important;height:48px!important;border-radius:17px!important;font-size:14px!important;font-weight:950!important}.navgroup{display:grid!important;gap:7px!important;margin:14px 0!important}.navlabel{padding:0 12px 2px!important;color:#64748b!important;font-size:10px!important;letter-spacing:.14em!important;text-transform:uppercase!important;font-weight:900!important}.nav button{position:relative!important}.nav button.active:before{content:'';position:absolute;left:-7px;top:12px;bottom:12px;width:3px;border-radius:99px;background:linear-gradient(#ff6b4a,#38bdf8)}.appbar{background:rgba(3,7,18,.72)!important;backdrop-filter:blur(18px)!important}.crumb{display:flex!important;flex-direction:column!important;gap:2px!important}.crumb b{font-size:13px!important}.crumb span{font-size:12px!important;color:#64748b!important}.top-actions,.hero-actions{display:flex!important;align-items:center!important;gap:9px!important;flex-wrap:wrap!important}.status-dot{width:10px;height:10px;border-radius:99px;background:#22c55e;box-shadow:0 0 0 6px rgba(34,197,94,.12),0 0 24px rgba(34,197,94,.6);display:inline-block}.hero{display:flex!important;align-items:flex-end!important;justify-content:space-between!important;gap:18px!important;margin-bottom:18px!important;padding:22px!important;border:1px solid rgba(148,163,184,.16)!important;border-radius:28px!important;background:linear-gradient(135deg,rgba(15,23,42,.72),rgba(37,99,235,.10)),radial-gradient(circle at 80% 10%,rgba(255,107,74,.18),transparent 28%)!important;box-shadow:0 30px 100px rgba(0,0,0,.22)!important}.eyebrow{font-size:11px!important;color:#38bdf8!important;text-transform:uppercase!important;letter-spacing:.18em!important;font-weight:950!important}.hero .title{margin:4px 0!important;font-size:clamp(34px,4vw,60px)!important}.grid{align-items:start!important}.card{position:relative!important;overflow:hidden!important}.card:after{content:'';position:absolute;inset:0;pointer-events:none;background:linear-gradient(135deg,rgba(255,255,255,.05),transparent 32%)!important}.card>*{position:relative!important;z-index:1}.card:hover{transform:translateY(-1px)!important;border-color:rgba(56,189,248,.34)!important}.num{background:linear-gradient(135deg,#f8fafc,#93c5fd)!important;-webkit-background-clip:text!important;color:transparent!important}.bad{color:#fb7185!important}.warn{color:#fbbf24!important}.ok{color:#86efac!important}table{width:100%!important;border-collapse:separate!important;border-spacing:0!important;overflow:hidden!important;border-radius:16px!important}th{background:rgba(15,23,42,.95)!important;text-transform:uppercase!important;font-size:11px!important;letter-spacing:.08em!important}td,th{border-bottom:1px solid rgba(148,163,184,.12)!important}pre,textarea{max-width:100%!important;white-space:pre-wrap!important;word-break:break-word!important}.form{align-items:end!important}.form button{min-height:45px!important}.badge{display:inline-flex!important;align-items:center!important;gap:6px!important;margin:3px!important}.sidefoot{margin-top:18px!important;padding-top:12px!important;border-top:1px solid rgba(148,163,184,.12)!important}

.layout-fix-marker{display:none}.grid>.card:not(.s3):not(.s4):not(.s6):not(.s8):not(.s9):not(.s12){grid-column:1/-1!important}.table-wrap{width:100%!important;max-width:100%!important;overflow-x:auto!important;overflow-y:hidden!important;-webkit-overflow-scrolling:touch!important;border:1px solid rgba(148,163,184,.12)!important;border-radius:16px!important}.table-wrap table{margin:0!important;border:0!important;min-width:max-content!important}table:after{content:none!important;display:none!important}.table-wrap:after{content:none!important;display:none!important}.card{overflow:visible!important}.card:after{border-radius:inherit!important}.head{display:flex!important;align-items:flex-start!important;justify-content:space-between!important;gap:12px!important;flex-wrap:wrap!important}.head>div{min-width:0!important}.head input,.head select{max-width:100%!important}.num{font-size:clamp(24px,3vw,42px)!important;line-height:1.05!important;overflow-wrap:anywhere!important;word-break:break-word!important}td,th{white-space:normal!important;word-break:break-word!important;vertical-align:top!important}td:last-child{min-width:170px!important}.form{width:100%!important}.form>*{min-width:0!important}pre{overflow:auto!important;max-height:62vh!important}.quickgrid{display:flex!important;gap:9px!important;flex-wrap:wrap!important;justify-content:flex-end!important}.quickgrid button{min-height:42px!important}.sysline{position:relative;display:grid;grid-template-columns:1fr auto;gap:10px;margin:14px 0;padding-bottom:15px;border-bottom:1px solid rgba(148,163,184,.10)}.sysline i{position:absolute;left:0;right:0;bottom:0;height:7px;border-radius:99px;background:rgba(148,163,184,.16);overflow:hidden}.sysline i:after{content:'';display:block;width:var(--w);height:100%;border-radius:99px;background:linear-gradient(90deg,#38bdf8,#2563eb,#ff6b4a)}.opslist{display:grid!important;grid-template-columns:1fr 1fr!important;gap:10px!important}.opslist button{width:100%!important}.card.s4 .opslist{margin-top:10px!important}@media(max-width:720px){.quickgrid,.hero-actions,.top-actions{justify-content:flex-start!important}.quickgrid button{width:100%!important}.opslist{grid-template-columns:1fr!important}.hero{align-items:flex-start!important;flex-direction:column!important}}

