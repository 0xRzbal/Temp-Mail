NODE_ENV=production
PORT=3000
DB_PATH=./database/joemail.db
JWT_SECRET=change-this-to-64-char-random-string-immediately
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2a$10$YourHashedPasswordHere
CORS_ORIGIN=https://mail.rzbal.biz.id,http://localhost:5173
SMTP_PORT=2525
SMTP_HOST=0.0.0.0
DOMAIN=mail.rzbal.biz.id
ALLOWED_DOMAINS=mail.rzbal.biz.id,temp.rzbal.biz.id,disposable.rzbal.biz.id
CUSTOM_DOMAINS_ENABLED=true
EMAIL_EXPIRY_HOURS=24
MAX_EMAIL_SIZE_MB=25
MAX_ATTACHMENTS=10
FORWARDING_ENABLED=true
FORWARDING_MAX_PER_EMAIL=5
WEBHOOKS_ENABLED=true
WEBHOOK_TIMEOUT_MS=5000
WEBHOOK_MAX_RETRIES=3
WEBHOOK_SECRET=webhook-signing-secret-change-this
API_KEYS_ENABLED=true
API_KEY_HEADER=X-API-Key
REPLY_ENABLED=true
REPLY_SMTP_HOST=smtp.gmail.com
REPLY_SMTP_PORT=587
REPLY_SMTP_USER=
REPLY_SMTP_PASS=
REPLY_FROM_NAME=JoeMail Reply
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
API_KEY_RATE_LIMIT_MAX=1000
CLEANUP_CRON=0 */1 * * *
WS_CORS_ORIGIN=https://mail.rzbal.biz.id
LOG_LEVEL=info
LOG_DIR=./logs
THEME_DEFAULT=dark
THEME_ALLOWED=dark,light,auto,contrast
