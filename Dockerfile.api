FROM node:18-alpine
WORKDIR /app
RUN npm init -y && npm install \
  express cors helmet express-rate-limit compression morgan winston \
  bcrypt jsonwebtoken speakeasy qrcode uuid@9 node-cron systeminformation \
  dotenv imap mailparser
COPY api-index.js /app/index.js
EXPOSE 3000
CMD ["node", "/app/index.js"]
